{
  "name": "@santicons/mcp",
  "version": "0.1.0",
  "description": "MCP server for sant.icons — search and retrieve from 69,000+ open-source SVG icons without leaving your terminal.",
  "type": "module",
  "bin": {
    "sant-icons-mcp": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "data", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-manifest.mjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "keywords": ["mcp", "icons", "svg", "claude", "model-context-protocol"],
  "author": "Sant <hello@sant.co.nz> (https://sant.co.nz)",
  "license": "MIT",
  "homepage": "https://icons.sant.co.nz"
}
